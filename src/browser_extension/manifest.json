{
  "manifest_version": 3,
  "name": "Agent Security Enforcer",
  "version": "1.0",
  "description": "Enforces security policies for AI Agents in the browser.",
  "permissions": [
    "webNavigation",
    "webRequest",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Agent Security Enforcer"
  }
}
